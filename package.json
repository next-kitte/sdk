{
  "name": "next-kitte",
  "version": "0.0.13",
  "author": "Gabriel Ribeiro",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielgrs/next-kitte"
  },
  "main": "dist/index.js",
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "add": "2.0.6",
    "bun": "1.3.12",
    "husky": "9.1.7",
    "react": "19.2.5",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "next": ">= 14.0.0",
    "react": ">= 18.2.0",
    "react-dom": ">= 18.2.0",
    "zod": ">= 3.22.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=18.17"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "next",
    "react",
    "react server components",
    "actions",
    "server actions"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "prepublishOnly": "npm run build",
    "biome": "biome check",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "prepare": "husky"
  },
  "type": "module",
  "types": "dist/index.d.ts"
}
