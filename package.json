{
  "name": "next-kitte",
  "version": "0.0.2",
  "main": "dist/index.js",
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "prepublishOnly": "npm run build",
    "biome": "biome check",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielgrs/next-kitte"
  },
  "dependencies": {
    "react": "19.2.5",
    "zod": "4.3.6"
  }
}
